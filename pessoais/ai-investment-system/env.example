# ─── AI Investment System — variáveis de ambiente ───────────────────────────
# Copie para .env e preencha com seus valores reais.
# NUNCA commite o .env no GitHub!

# ── Anthropic (obrigatório) ──────────────────────────────────────────────────
# Gere em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-

# ── brapi.dev — ações brasileiras (gratuito com limite) ─────────────────────
# Crie conta em: https://brapi.dev
BRAPI_TOKEN=

# ── Alpha Vantage — dados internacionais (opcional) ──────────────────────────
# Gratuito com limite: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# ── Telegram Bot (opcional mas recomendado) ──────────────────────────────────
# 1. Fale com @BotFather no Telegram → /newbot → copie o token
# 2. Envie uma mensagem pro bot e acesse:
#    https://api.telegram.org/bot<TOKEN>/getUpdates → copie o chat_id
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Portfólio ────────────────────────────────────────────────────────────────
INITIAL_CAPITAL=10000       # capital inicial em R$

# ── Banco de dados ───────────────────────────────────────────────────────────
# SQLite para dev, TimescaleDB para produção
DATABASE_URL=sqlite:///investment.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/investment

# ── Redis (opcional — remove cache em memória se não tiver) ─────────────────
REDIS_URL=redis://localhost:6379
